<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>For Stelios ❤️</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  text-align: center;
  background-color: #bde0fe; /* baby blue */
  transition: 0.8s;
}

.container {
  padding: 40px;
}

img {
  width: 250px;
  border-radius: 20px;
}

h1 {
  margin-top: 20px;
}

button {
  margin-top: 20px;
  padding: 15px 25px;
  font-size: 20px;
  border: none;
  border-radius: 20px;
  background-color: #ffafcc;
  cursor: pointer;
}

.hidden {
  display: none;
}

/* Second state */
.love-mode {
  background-color: #ffc8dd;
}

.hearts {
  position: fixed;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.heart {
  position: absolute;
  color: red;
  font-size: 24px;
  animation: float 5s linear infinite;
}

@keyframes float {
  from { transform: translateY(100vh); }
  to { transform: translateY(-10vh); }
}
</style>

</head>

<body>

<div class="container" id="firstScreen">
  <img src="https://images.unsplash.com/photo-1518199266791-5375a83190b7" />
  
  <h1>If your name is Stelios, press the button</h1>
  
  <button onclick="showLove()">❤️</button>
</div>

<div class="container hidden" id="secondScreen">
  <h1>I love you so much ❤️</h1>
  <p>You make my days better 🌸</p>
</div>

<div class="hearts" id="hearts"></div>

<script>
function showLove() {
  document.getElementById("firstScreen").classList.add("hidden");
  document.getElementById("secondScreen").classList.remove("hidden");
  document.body.classList.add("love-mode");

  createHearts();
}

function createHearts() {
  const heartsContainer = document.getElementById("hearts");

  for (let i = 0; i < 30; i++) {
    let heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = (Math.random() * 3 + 2) + "s";

    heartsContainer.appendChild(heart);
  }
}
</script>

</body>
</html>
